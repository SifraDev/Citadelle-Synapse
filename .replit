modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_API_TOKEN = "58608c0e77248d2dfc08bbb8433d4606f2ca821f5526a2f0dab31914797ae3f0"
VITE_ADMIN_API_TOKEN = "58608c0e77248d2dfc08bbb8433d4606f2ca821f5526a2f0dab31914797ae3f0"
